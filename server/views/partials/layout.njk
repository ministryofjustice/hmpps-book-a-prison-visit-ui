{% extends "govuk/template.njk" %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/header/macro.njk" import govukHeader %}
{% from "govuk/components/service-navigation/macro.njk" import govukServiceNavigation %}
{% from "service-header/service-header.njk" import govukOneLoginServiceHeader %}
{% from "govuk/components/phase-banner/macro.njk" import govukPhaseBanner %}
{% from "components/language-toggle/macro.njk" import visitsLanguageToggle %}

{% set navigationItems = [
  {
    href: paths.VISITS.HOME,
    text: t("common:navigation.visits"),
    id: "visits-link",
    active: true if activeLink == "visits-link"
  },
  {
    href: paths.VISITORS,
    text: t("common:navigation.visitors"),
    id: "visitors-link",
    active: true if activeLink == "visitors-link"
  }
  ] if showOLServiceNav
%}
{% set serviceName = t("common:applicationName") %}
{% set signOutLink = paths.SIGN_OUT %}

{% set bodyAttributes = {
  "data-google-analytics-id": googleAnalyticsId
} %}

{% set bodyClasses = ("env--" + environmentName) if environmentName %}

{% block head %}
  {% if analyticsEnabled %}
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ googleAnalyticsId }}" data-test="google-analytics"></script>
    <script nonce="{{ cspNonce }}">
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', '{{ googleAnalyticsId }}');
    </script>
  {% endif %}

  <link href="/assets/stylesheets/application.css?{{ version }}" rel="stylesheet"/>
{% endblock %}

{% block pageTitle -%}
  {{ t("errors:errorTitlePrefix") + ": " if errors | length }}{{ pageTitle + " - " if pageTitle }}{{ serviceName }} - GOV.UK
{%- endblock %}

{% block bodyStart %}
  {% if analyticsEnabled == undefined %}
    {%- include "partials/cookieBanner.njk" -%}
  {% endif %}
{% endblock %}

{% block govukHeader %}
{# If user authenticated then use GOVUK One Login Header; otherwise default header #}
{% if user and user.sub %}
  {{ govukOneLoginServiceHeader({ 
    signOutLink: signOutLink,
    oneLoginLink: oneLoginLink,
    lng: language
  }) }}
{% else %}
  {{ govukHeader({
    homepageUrl: "https://www.gov.uk"
  }) }}
{% endif %}
{% endblock %}
{% block govukServiceNavigation %}
  {{ govukServiceNavigation({
    serviceName: serviceName,
    navigation: navigationItems,
    collapseNavigationOnMobile: false
  }) }}
{% endblock %}

{% block beforeContent %}
  {{ govukPhaseBanner({
    tag: {
      text: t("common:phase.beta")
    },
    attributes: {
      role: "complementary"
    },
    html: t("common:phase.feedback")
  }) }}

  {% if backLinkHref %}
    <div class="govuk-!-display-inline" role="navigation">
      {{ govukBackLink({
        text: t("common:links.back"),
        href: backLinkHref,
        attributes: { "data-test": "back-link" }
      }) }}
    </div>
  {% endif %}

  {{ visitsLanguageToggle({
    selectedLang: language,
    href: {
      en: currentUrlEn.pathname + currentUrlEn.search,
      cy: currentUrlCy.pathname + currentUrlCy.search
    }
  }) if features.welshLanguageEnabled }}
{% endblock %}

{% block footer %}
  {% set footerLinks = [
    {
      href: paths.ACCESSIBILITY,
      text: t("common:footer.accessibility")
    },
    {
      href: paths.COOKIES,
      text: t("common:footer.cookies")
    },
    {
      href: paths.PRIVACY,
      text: t("common:footer.privacy")
    },
    {
      href: paths.TERMS,
      text: t("common:footer.terms")
    }
  ] %}

  {{ govukFooter({
    meta: {
      items: [] if hideFooterLinks else footerLinks
    }
  }) }}
{% endblock %}

{% block bodyEnd %}
  {# Run JavaScript at end of the <body>, to avoid blocking the initial render. #}
  <script type="module" src="/assets/govukFrontendInit.js"></script>
  <script type="module" src="/assets/govukOneLoginHeaderInit.js"></script>
  <script src="/assets/cookieBanner.js"></script>
{% block pageScripts %}
{% endblock %}
{% endblock %}
