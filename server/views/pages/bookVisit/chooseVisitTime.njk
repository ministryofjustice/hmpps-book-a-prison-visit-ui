{% extends "partials/layout.njk" %}

{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{%- from "moj/components/alert/macro.njk" import mojAlert -%}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}

{% set pageTitle = t("bookVisit:chooseVisitTime.title") %}

{% block content %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">

      {# Messages #}
      {% for message in messages %}
        {{ mojAlert(message) }}
      {% endfor %}

      {% include "partials/errorSummary.njk" %}

      <h1 class="govuk-heading-l">{{ pageTitle }}</h1>
    </div>
  </div>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <p>{{ t("bookVisit:chooseVisitTime.reservationTime") }}</p>
      <p data-test="prisoner-visit-times">
        {{- t("bookVisit:chooseVisitTime.prisonerVisitTimes", { name: prisoner | prisonerNameFirstLast }) -}}
      </p>

      {# Banned visitor details #}
      {% if bannedVisitors | length %}
        {% call govukInsetText({
          attributes: { "data-test": "banned-visitors-details" }
        }) -%}
          {% for visitor in bannedVisitors %}
            <span data-test="banned-visitor-{{ loop.index }}">
              {{- t("common:visitors.bannedUntil", {
                name: visitor.firstName + " " + visitor.lastName,
                date: visitor.banExpiryDate | formatDate(dateFormats.DISPLAY_DATE, language)
              }) -}}
            </span>
            <br>
          {% endfor -%}
          {{ t("bookVisit:chooseVisitTime.onlyAfterDate") }}
        {%- endcall %}
      {% endif %}

      <nav class="visits-calendar" aria-label="{{ t('bookVisit:chooseVisitTime.calendarAriaLabel') }}" role="navigation">
        {# Loop over months #}
        {% for monthName, monthData in calendar %}
          <h2 class="govuk-heading-m">{{ monthName | formatDate(dateFormats.DISPLAY_DATE_MONTH_YEAR, language) }}</h2>

          {# Day name headings on first month only #}
          {% if loop.first %}
            {# Single letter day headings for mobile #}
            <ul class="govuk-list visits-calendar__day-headings visits-calendar__day-headings--single-letter" aria-hidden="true">
              <li>{{ t("common:days.singleLetter.monday") }}</li>
              <li>{{ t("common:days.singleLetter.tuesday") }}</li>
              <li>{{ t("common:days.singleLetter.wednesday") }}</li>
              <li>{{ t("common:days.singleLetter.thursday") }}</li>
              <li>{{ t("common:days.singleLetter.friday") }}</li>
              <li>{{ t("common:days.singleLetter.saturday") }}</li>
              <li>{{ t("common:days.singleLetter.sunday") }}</li>
            </ul>
            {# Short name day headings for tablet and desktop #}
            <ul class="govuk-list visits-calendar__day-headings visits-calendar__day-headings--short" aria-hidden="true">
              <li>{{ t("common:days.short.monday") }}</li>
              <li>{{ t("common:days.short.tuesday") }}</li>
              <li>{{ t("common:days.short.wednesday") }}</li>
              <li>{{ t("common:days.short.thursday") }}</li>
              <li>{{ t("common:days.short.friday") }}</li>
              <li>{{ t("common:days.short.saturday") }}</li>
              <li>{{ t("common:days.short.sunday") }}</li>
            </ul>
          {% endif %}

          <ul class="govuk-list visits-calendar__month">
            {# Days for this month #}
            {% for date, sessions in monthData %}
              {%- set numberOfSessions = sessions | length -%}
              <li data-date="{{ date }}" class="visits-calendar__day
                {%- if loop.first %} visits-calendar__day--start-col-{{ date | formatDate("i", language) }}{% endif %} {# add column offset based on ISO day of week (1-7) #}
                {%- if selectedDate == date %} visits-calendar__day--selected
                {%- endif %}"
                {%- if not numberOfSessions %}aria-hidden="true"{% endif %}>

                {%- if numberOfSessions %}
                  <a id="day-link-{{ date }}" href="#day-group-{{ date }}">
                    {{ date | formatDate("d", language) }}
                    <span class="govuk-visually-hidden">
                      {{- t("bookVisit:chooseVisitTime.availableTimesForDate", {
                        date: date | formatDate("MMMM - eeee", language),
                        count: numberOfSessions
                      }) -}}
                    </span>
                  </a>
                {% else %}
                    <span>{{ date | formatDate("d", language) }}</span>
                    <span class="govuk-visually-hidden">
                      {{- t("bookVisit:chooseVisitTime.availableTimesForDate", {
                        date: date | formatDate("MMMM - eeee", language),
                        count: 0
                      }) -}}
                    </span>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        {% endfor %}
      </nav>

      <form action="{{ paths.BOOK_VISIT.CHOOSE_TIME }}" method="POST" novalidate class="disable-button-on-submit">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        {# Build radio visit session items from months/dates/sessions data #}
        {% for monthName, monthData in calendar %}
          {% for date, sessions in monthData %}
            {% if sessions | length %}
              {% set visitSessionItems = [] %}
              {% for session in sessions %}
                {% set radioValue = date + "_" + session.reference %}
                {% set visitSessionItems = (visitSessionItems.push({
                  value: radioValue,
                  html:
                    t("common:dateTime.timeRange", {
                      startTime: session.startTime | formatTime(language),
                      endTime: session.endTime | formatTime(language)
                    }) +
                    ' <span class="visits-calendar__session-duration">(' +
                      (session.startTime | formatTimeDuration(session.endTime, language)) +
                    ')</span>',
                  checked: formValues.visitSession == radioValue
                }), visitSessionItems) %}
              {% endfor %}

              {{ govukRadios({
                name: "visitSession",
                idPrefix: "date-" + date,
                formGroup: {
                  classes: "visits-calendar__day-group",
                  attributes: { "data-date": date },
                  afterInputs: {
                    html: '<p><a class="govuk-visually-hidden-focusable govuk-!-display-inline-block govuk-!-margin-top-5" href="#day-link-' +
                      date + '">' + t("bookVisit:chooseVisitTime.chooseDifferentDate") + '</a></p>'
                  }
                },
                fieldset: {
                  attributes: { id: 'day-group-' + date },
                  legend: {
                    text: date | formatDate(dateFormats.DISPLAY_DATE_WITH_DAY, language),
                    classes: "govuk-fieldset__legend--s"
                  }
                },
                hint: {
                  text: t("bookVisit:chooseVisitTime.chooseOneOption"),
                  classes: "govuk-visually-hidden"
                },
                items: visitSessionItems,
                errorMessage: errors | findError('date-' + firstSessionDate)
              }) }}
            {% endif %}
          {% endfor %}
        {% endfor %}

        {{ govukButton({
          text: t("common:buttons.continue"),
          attributes: { "data-test": "continue-button" },
          preventDoubleClick: true
        }) }}

      </form>

    </div>
  </div>
{% endblock %}

{% block pageScripts %}
<script src="/assets/visitsCalendar.js"></script>
<script src="/assets/disableButtonOnSubmit.js"></script>
{% endblock %}
