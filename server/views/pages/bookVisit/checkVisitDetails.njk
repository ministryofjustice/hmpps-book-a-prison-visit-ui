{% extends "partials/layout.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% set pageTitle = t("bookVisit:checkVisitDetails.title") %}

{% set backLinkHref = paths.BOOK_VISIT.CONTACT_DETAILS %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-three-quarters">

      <h1 class="govuk-heading-l">{{ pageTitle }}</h1>

      {%- set visitorsHtml -%}
        {% for visitor in visitors %}
          <p><span data-test="visitor-name-{{ loop.index }}">{{ visitor.firstName }} {{ visitor.lastName }} ({{ visitor.dateOfBirth | displayAge(t) }})</span></p>
        {% endfor %}
      {%- endset -%}

      {{ govukSummaryList({
        rows: [
          {
            key: {
              text: t("common:labels.prisoner")
            },
            value: {
              html: '<span data-test="prisoner-details">' +
                t("bookVisit:checkVisitDetails.prisonerAtPrison", {
                  name: prisoner | prisonerNameFirstLast,
                  prisonName: prisoner.prisonId | getPrisonName(prisonNames, language)
                }) + "</span>"
            }
          },

          {
            key: {
              text: t("common:labels.visitors")
            },
            value: {
              html: visitorsHtml
            },
            actions: {
              items: [
                {
                  href: paths.BOOK_VISIT.SELECT_VISITORS,
                  text: t("common:buttons.change"),
                  classes: "govuk-link--no-visited-state",
                  visuallyHiddenText: t("bookVisit:checkVisitDetails.changeVisitors"),
                  attributes: { "data-test": "change-visitors" }
                }
              ]
            }
          },

          {
            key: {
              text: t("common:labels.dateAndTime")
            },
            value: {
              html: '<p><span data-test="visit-date">' +
                  sessionDate | formatDate(dateFormats.DISPLAY_DATE_WITH_DAY, language) +
                "</span></p>" +
                '<p><span data-test="visit-time">' + t("common:dateTime.timeRange", {
                  startTime: sessionTimeSlot.startTime | formatTime(language),
                  endTime: sessionTimeSlot.endTime | formatTime(language)
                }) + "</span></p>"
            },
            actions: {
              items: [
                {
                  href: paths.BOOK_VISIT.CHOOSE_TIME,
                  text: t("common:buttons.change"),
                  classes: "govuk-link--no-visited-state",
                  visuallyHiddenText: t("bookVisit:checkVisitDetails.changeDateAndTime"),
                  attributes: { "data-test": "change-time" }
                }
              ]
            }
          },

          {
            key: {
              text: t("common:labels.additionalSupport")
            },
            value: {
              html: '<p data-test="additional-support">' + additionalSupport | d(t("common:labels.none"), true) | escape + "</p>"
            },
            actions: {
              items: [
                {
                  href: paths.BOOK_VISIT.ADDITIONAL_SUPPORT,
                  text: t("common:buttons.change"),
                  classes: "govuk-link--no-visited-state",
                  visuallyHiddenText: t("bookVisit:checkVisitDetails.changeAdditionalSupport"),
                  attributes: { "data-test": "change-additional-support" }
                }
              ]
            }
          },

          {
            key: {
              text: t("common:labels.mainContact")
            },
            value: {
              html: '<p><span data-test="main-contact-name">' + mainContactName | escape + "</span></p>"
            },
            actions: {
              items: [
                {
                  href: paths.BOOK_VISIT.MAIN_CONTACT,
                  text: t("common:buttons.change"),
                  classes: "govuk-link--no-visited-state",
                  visuallyHiddenText: t("bookVisit:checkVisitDetails.changeMainContact"),
                  attributes: { "data-test": "change-main-contact" }
                }
              ]
            }
          },

          {
            key: {
              text: t("common:labels.contactDetails")
            },
            value: {
              html: '<p><span data-test="contact-details-email">' + mainContactEmail | escape + "</span></p>" +
                    '<p><span data-test="contact-details-phone">' + mainContactPhone | escape + "</span></p>"
                      if mainContactEmail or mainContactPhone else
                    '<p><span data-test="no-contact-details">' + t("common:labels.noContactDetails") + '</span>'
            },
            actions: {
              items: [
                {
                  href: paths.BOOK_VISIT.CONTACT_DETAILS,
                  text: t("common:buttons.change"),
                  classes: "govuk-link--no-visited-state",
                  visuallyHiddenText: t("bookVisit:checkVisitDetails.changeContactDetails"),
                  attributes: { "data-test": "change-contact-details" }
                }
              ]
            }
          }
        ]
      }) }}

      <form action="{{ paths.BOOK_VISIT.CHECK_DETAILS }}" method="POST" novalidate class="disable-button-on-submit">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        {{ govukButton({
          text: t("common:buttons.confirmAndSend"),
          preventDoubleClick: true,
          attributes: { "data-test": "submit" }
        }) }}
      </form>
    </div>
  </div>

{% endblock %}

{% block pageScripts %}
<script src="/assets/disableButtonOnSubmit.js"></script>
{% endblock %}
