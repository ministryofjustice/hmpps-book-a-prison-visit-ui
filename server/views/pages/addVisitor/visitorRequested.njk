{% extends "partials/layout.njk" %}
{% from "govuk/components/panel/macro.njk" import govukPanel %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% set pageTitle = t("addVisitor:visitorRequested.title") %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {{ govukPanel({
        titleText: pageTitle,
        classes: "visits-request-confirmation",
        text: t("addVisitor:visitorRequested.requestReview")
      }) }}

      <p>{{ t("addVisitor:visitorRequested.approvedOrRejected") }}</p>

      <p>
        {{- t("addVisitor:visitorRequested.statusOnVisitorsPage", {
          url: paths.VISITORS
        }) | safe -}}
      </p>

      {{ govukButton({
        text: t("common:buttons.linkAnotherVisitor"),
        href: paths.ADD_VISITOR.DETAILS,
        classes: "govuk-button--secondary",
        attributes: { "data-test": "link-a-visitor" },
        preventDoubleClick: true
      }) }}
    </div>
  </div>
{% endblock %}
